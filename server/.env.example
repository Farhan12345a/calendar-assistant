# Copy to .env and fill in. See ../MANUAL_GOOGLE_CLOUD_SETUP.md for Google Cloud steps (not done in code).

PORT=3001
# Preferred frontend origin variable
CLIENT_ORIGIN=http://localhost:5173
# Backward-compatible alias also supported by this server
# FRONTEND_URL=http://localhost:5173

# Google OAuth (Web client) — from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3001/auth/google/callback
# Backward-compatible alias also supported by this server
# GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Random secret for cookie-session (use a long random string in production)
SESSION_SECRET=

# OpenAI — from https://platform.openai.com/
OPENAI_API_KEY=
# Optional — default used if unset
# OPENAI_MODEL=gpt-4o-mini

# Optional IANA timezone for chat/calendar copy when the client does not send one
# DEFAULT_TIME_ZONE=America/New_York
